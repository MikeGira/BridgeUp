# ============================================================================
# BridgeUp — Environment Variables
# Copy this to .env and fill in your values.
# NEVER commit .env — all secrets go in Vercel dashboard env vars.
# ============================================================================

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Supabase (replaces Firebase) ────────────────────────────────────────────
# Get from: Supabase dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # Service role key (server-side only!)
# SUPABASE_ANON_KEY not used — all access via server-side service key

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SESSION_SECRET=your-minimum-32-character-random-secret-here

# ─── Twilio (SMS + Voice OTP) ─────────────────────────────────────────────────
# Get from: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Phone numbers (buy from Twilio Console → Phone Numbers)
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx         # Default outbound number
TWILIO_CANADA_NUMBER=+1xxxxxxxxxx        # For +1 (Canada/USA) destination
TWILIO_RWANDA_NUMBER=+250xxxxxxxxx       # For +250 (Rwanda) destination
TWILIO_KENYA_NUMBER=+254xxxxxxxxxx       # For +254 (Kenya) destination

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Payments ─────────────────────────────────────────────────────────────────
# Stripe (Canada/USA) — get from: dashboard.stripe.com
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Flutterwave (Africa) — get from: dashboard.flutterwave.com
FLW_PUBLIC_KEY=FLWPUBK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_SECRET_KEY=FLWSECK-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-X
FLW_WEBHOOK_HASH=your_flw_webhook_verification_hash

# Africa's Talking (SMS payments) — get from: africastalking.com
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
AFRICASTALKING_SENDER_ID=BridgeUp

# ─── Email (optional — for scheduled reports) ────────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SMTP_FROM=BridgeUp Reports <reports@yourdomain.com>

# ─── Frontend / CORS ──────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
FRONTEND_URL=https://your-project.vercel.app

# ─── Vercel CI/CD secrets ─────────────────────────────────────────────────────
# Add these in GitHub → Settings → Secrets → Actions (NOT in .env):
# VERCEL_TOKEN          - Vercel dashboard → Settings → Tokens
# VERCEL_ORG_ID         - Vercel dashboard → Settings → General → Team ID
# VERCEL_PROJECT_ID     - Vercel project → Settings → General → Project ID
# SITE_URL              - Your production URL for smoke tests
